# Example environment for local development.
# Copy secrets/app.env.example to secrets/app.env for docker-compose,
# or export these variables before running the Flask app directly.

# Required. Use a long random value and keep it stable for an existing database.
APP_SECRET=replace-with-a-long-random-secret

# Optional. Defaults to ./data when running locally; docker-compose sets /app/data.
DATA_DIR=data
